# =========================================
# NutriBerg — Environment Variables
# =========================================
# Copy this file to .env and fill in the values
# cp .env.example .env

# ---- Spoonacular API ----
# Get your free API key at: https://spoonacular.com/food-api
# Free tier: 150 requests/day (sufficient for development)
VITE_SPOONACULAR_API_KEY=your_spoonacular_api_key_here

# ---- AWS Configuration ----
# These values come from the SAM deployment output
VITE_AWS_REGION=us-east-1
VITE_API_URL=https://your-api-id.execute-api.us-east-1.amazonaws.com/dev
VITE_COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
VITE_COGNITO_CLIENT_ID=your_cognito_client_id_here

# ---- S3 Configuration ----
VITE_S3_MEDIA_BUCKET=nutriberg-media-dev-123456789012
VITE_CLOUDFRONT_URL=https://dxxxxxxxxxx.cloudfront.net

# ---- App Configuration ----
VITE_APP_NAME=NutriBerg
VITE_APP_ENV=development
